{
  "expo": {
    "name": "My Overtime",
    "slug": "my-overtime-v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f3460"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#0f3460"
      },
      "package": "com.aakash.myovertime",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6032254677631992~8456018863"
        }
      ]
    ]
  }
}
